```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.out
dist/
build/
target/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# System files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
*.class
*.jar
*.war
*.ear
hs_err_pid*

# C/C++ specific
*.a
*.lib
*.dll
*.dylib
*.so

# Go specific
*.exe
*.test
*.prof

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
