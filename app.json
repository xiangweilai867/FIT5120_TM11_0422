{
  "expo": {
    "name": "NutriHeroes",
    "slug": "NutriHeroes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nutriheroes_icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6F8EC",
        "foregroundImage": "./assets/images/nutriheroes_logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.NutriHeroes"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/nutriheroes_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/nutriheroes_icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F6F8EC",
          "dark": {
            "backgroundColor": "#F6F8EC"
          }
        }
      ],
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
