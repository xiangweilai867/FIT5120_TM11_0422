# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/nutrihealth
# For render.com, this will be provided automatically as DATABASE_URL

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Get your API key from: https://makersuite.google.com/app/apikey

# JWT Authentication
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_-hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
# Hardcoded credentials for demo: username=demo, password=demo123

# CORS Configuration
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
# Add your production URLs here when deploying
# Example: https://your-app.com,https://www.your-app.com

# Environment
ENVIRONMENT=development
# Options: development, production
