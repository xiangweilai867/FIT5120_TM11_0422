# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nutrihealth
# On render.com, DATABASE_URL is provided automatically as an environment variable.

# ─── OpenAI (Primary vision + text LLM) ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# Vision model used for food image analysis (default: gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini
# Fallback vision model used when mini returns low-confidence results (default: gpt-4o)
# OPENAI_VISION_FALLBACK_MODEL=gpt-4o
# Text model used for alternatives rewrite (default: gpt-4o-mini)
# OPENAI_TEXT_MODEL=gpt-4o-mini

# ─── DashScope / Qwen-VL (Fallback when OpenAI quota is exhausted) ────────────
# Console: https://bailian.console.aliyun.com/ → API Key
# Write the real key in .env (do not commit to repo), this file is a placeholder only.
# DASHSCOPE_API_KEY=sk-your-dashscope-key-here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_VL_MODEL=qwen3-vl-plus
# QWEN_TEXT_MODEL=qwen-plus
# QWEN_VL_STREAM=false
# QWEN_VL_ENABLE_THINKING=false
# QWEN_VL_THINKING_BUDGET=81920

# ─── JWT Authentication ───────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
# Demo credentials: username=demo, password=demo123

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://fit5120-tm11.onrender.com
# Add production URLs when deploying, e.g.:
# CORS_ORIGINS=https://your-app.com,https://www.your-app.com

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Options: development, production

# ─── RAG / Embeddings ─────────────────────────────────────────────────────────
# Embeddings are generated via DashScope (Qwen) API. DASHSCOPE_API_KEY is reused.
# Default embedding model: text-embedding-v3
# QWEN_EMBEDDING_MODEL=text-embedding-v3

# ─── Caching ──────────────────────────────────────────────────────────────────
# Set to false to disable caching AI scan responses in the database
# CACHE_AI_RESPONSE=true
